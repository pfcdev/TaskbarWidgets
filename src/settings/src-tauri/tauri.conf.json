{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taskbar Widgets Settings",
  "version": "0.3.0",
  "identifier": "com.taskbarwidgets.settings",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Taskbar Widgets Settings",
        "width": 1100,
        "height": 720,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
