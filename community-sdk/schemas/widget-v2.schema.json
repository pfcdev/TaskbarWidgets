{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taskbarwidgets.dev/schemas/widget-v2.schema.json",
  "title": "Taskbar Widgets Community Manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "version", "minHostVersion", "displayName", "description", "author", "size", "entry", "permissions"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{2,127}\\.[a-z0-9.-]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "minHostVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "category": { "type": "string", "maxLength": 40 },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "website": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 32, "maximum": 480 },
        "height": { "type": "integer", "minimum": 24, "maximum": 48 }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout"],
      "properties": {
        "layout": { "type": "string", "pattern": "^[^/\\\\]+\\.json$" },
        "provider": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["static", "clock", "http-json", "javascript"] },
            "path": { "type": "string", "pattern": "^[^/\\\\]+\\.js$" },
            "url": { "type": "string", "format": "uri", "pattern": "^https://" },
            "refreshSeconds": { "type": "number", "minimum": 1, "maximum": 3600 },
            "data": { "type": "object" }
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": { "type": "array", "uniqueItems": true, "items": { "type": "string", "format": "hostname" } },
        "systemMetrics": { "type": "array", "uniqueItems": true, "items": { "enum": ["cpu", "storage", "network", "memory"] } },
        "openExternal": { "type": "array", "items": { "type": "string", "format": "hostname" } },
        "storage": { "type": "boolean" }
      }
    },
    "supportsMultipleInstances": { "type": "boolean", "default": false },
    "settings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["key", "type", "label", "default"],
        "properties": {
          "key": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,63}$" },
          "type": { "enum": ["string", "number", "boolean", "select", "secret"] },
          "label": { "type": "string", "maxLength": 80 },
          "description": { "type": "string", "maxLength": 240 },
          "default": {},
          "minimum": { "type": "number" },
          "maximum": { "type": "number" },
          "step": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    }
  }
}
