{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pfcdev/TaskbarWidgets/blob/main/widgets/widget.schema.json",
  "title": "Taskbar Widgets manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "displayName", "category", "description", "defaultSize", "settings"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "displayName": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "defaultSize": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 32, "maximum": 480 },
        "height": { "type": "integer", "minimum": 24, "maximum": 80 }
      }
    },
    "assets": { "type": "array", "items": { "type": "string" }, "default": [] },
    "settings": { "type": "array", "items": { "$ref": "#/$defs/setting" } }
  },
  "$defs": {
    "setting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "type", "label"],
      "properties": {
        "key": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
        "type": { "enum": ["boolean", "number", "text", "select", "secret"] },
        "label": { "type": "string" },
        "default": {},
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "step": { "type": "number", "exclusiveMinimum": 0 },
        "options": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
