{
  "$schema": "../widget.schema.json",
  "schemaVersion": 1,
  "id": "system-storage",
  "displayName": "Storage",
  "category": "System",
  "description": "Live disk read and write throughput.",
  "defaultSize": { "width": 93, "height": 24 },
  "assets": [],
  "settings": [
    { "key": "displayMode", "type": "select", "label": "Display mode", "default": "text", "options": ["text", "bar", "pie"] },
    { "key": "meterStyleVersion", "type": "number", "label": "Meter style version", "default": 1 },
    { "key": "refreshSeconds", "type": "number", "label": "Refresh interval", "default": 3, "minimum": 0.1, "maximum": 10, "step": 0.1 },
    { "key": "outlineColor", "type": "text", "label": "Outline color", "default": "#FFFFFFFF" },
    { "key": "readColor", "type": "text", "label": "Read color", "default": "#FFFFFFFF" },
    { "key": "writeColor", "type": "text", "label": "Write color", "default": "#FFFFFFFF" },
    { "key": "diskId", "type": "select", "label": "Disk", "default": "_Total", "options": ["_Total"] }
  ]
}
